<?xml version="1.0"?>
<robot name="robot_lab" xmlns:xacro="http://ros.org/wiki/xacro"> 

<!-- Parametros Globales -->
  
  <xacro:property name="package_name" value="robot_description"/>
  <xacro:property name="PI" value="3.14159265"/>

  <xacro:arg name="base_color" default="0.0 0.0 1.0 1.0"/>
  
  <material name="gray">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>



 <!-- Parametros del Robot --> 
  
  <xacro:property name="body_length" value="0.48"/>
  <xacro:property name="body_width" value="0.30"/>
  <xacro:property name="body_height" value="0.79"/>
  <xacro:property name="base_elevation" value="0.10"/> 
  <xacro:property name="wheel_separation" value="0.26"/>
  <xacro:property name="wheel_separation_y" value="${body_length/2+0.05}"/>
  <xacro:property name="wheel_diameter" value="0.13"/>
  <xacro:property name="wheel_radius" value="${wheel_diameter/2}"/>
  <xacro:property name="caster_wheel_radius" value="${base_elevation/2}"/>
  <xacro:property name="wheel_thickness" value="0.03"/>
  <xacro:property name="wheel_z_offset" value="-0.035"/> 



   <!-- Base Footprint (distancia desde el suelo hasta el piso) --> 


  <link name="base_footprint"/>

  <!-- Base footprint to Base Link (cuerpo del robot (prisma rectangular de 0.79x0.30x0.48 )) --> 

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_elevation}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_length} ${body_height}"/>
      </geometry>
      <material name="base_color">
        <color rgba="$(arg base_color)"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_length} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.714" ixy="0.0" ixz="0.0" iyy="0.854" iyz="0.0" izz="0.320" />
    </inertial>
  </link>

<!-- /////////////////////////////////// RUEDAS CON MOTOR //////////////////////////////////////// -->   

<!-- Base Link to wheel_left_link (Union de la rueda izquierda con el cuerpo )) --> 

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.10 ${wheel_separation_y} ${wheel_z_offset}" rpy="${-PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" velocity="10"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.00024" ixy="0.0" ixz="0.0" iyy="0.00024" iyz="0.0" izz="0.00042" />
    </inertial>
  </link>

  <!-- Base Link to wheel_right_link (Union de la rueda derecha con el cuerpo )) --> 

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.10 ${-(wheel_separation_y)} ${wheel_z_offset}" rpy="${-PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" velocity="10"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${wheel_thickness}" radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.00024" ixy="0.0" ixz="0.0" iyy="0.00024" iyz="0.0" izz="0.00042" />
    </inertial>
  </link>


<!-- ////////////////////////////////////////////////RUEDAS LOCAS //////////////////////////////////////////////////////////////////////////////////////////--> 

<!-- Base Link to caster_left_joint (Union de la rueda loca izquiERDA con el cuerpo )) --> 

  <joint name="caster_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_left_link"/>
    <origin xyz="${-body_width/2} ${wheel_separation/2} ${wheel_z_offset}" rpy="${-PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="caster_left_link">
    <visual>
      <geometry>
        <sphere radius="${caster_wheel_radius}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.00024" ixy="0.0" ixz="0.0" iyy="0.00024" iyz="0.0" izz="0.00042" />
    </inertial>
  </link>

<!-- Base Link to caster_right_joint (Union de la rueda loca derecha con el cuerpo )) --> 

  <joint name="caster_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_right_link"/>
    <origin xyz="${-body_width/2} ${-wheel_separation/2} ${wheel_z_offset}" rpy="${-PI/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>


  <link name="caster_right_link">
    <visual>
      <geometry>
        <sphere radius="${caster_wheel_radius}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.00024" ixy="0.0" ixz="0.0" iyy="0.00024" iyz="0.0" izz="0.00042" />
    </inertial>
  </link>

<!-- /////////////////////////////////////////////// LIDAR //////////////////////////////////////////////////////////////////////////////// --> 

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.81" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

<!-- /////////////////////////////////////////////// CAMARA //////////////////////////////////////////////////////////////////////////////// -->   

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${body_width/2} 0 0.75" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.05 0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <topic>camera/image_raw</topic>
    </sensor>
  </gazebo>
<!-- /////////////////////////////////////////////// ODOMETRIA //////////////////////////////////////////////////////////////////////////////// --> 
  <gazebo>
    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>${wheel_separation_y}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <min_linear_acceleration>-0.5</min_linear_acceleration>
      <max_angular_acceleration>1</max_angular_acceleration>
      <min_angular_acceleration>-1</min_angular_acceleration>
      <max_linear_velocity>0.5</max_linear_velocity>
      <min_linear_velocity>-0.3</min_linear_velocity>
      <max_angular_velocity>1</max_angular_velocity>
      <min_angular_velocity>-1</min_angular_velocity>
    </plugin>

    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>
  </gazebo>

</robot>